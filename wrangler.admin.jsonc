{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "resume-v3-admin",
  "compatibility_date": "2026-07-23",
  "main": "./worker/index.js",
  "keep_vars": true,
  "assets": {
    "directory": "./dist-admin",
    "binding": "ASSETS",
    "run_worker_first": true,
    "not_found_handling": "single-page-application"
  }
}
